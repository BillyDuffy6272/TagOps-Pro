{
  "name": "tagops-pro-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop shell for TagOps Pro (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --mac --dir"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "au.noetica.tagops-pro",
    "productName": "TagOps Pro",
    "directories": {
      "output": "out"
    },
    "files": [
      "main.js",
      "preload.cjs"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "renderer"
      }
    ],
    "mac": {
      "identity": null,
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  }
}
